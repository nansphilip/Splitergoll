TAP_DANCE_3(ag_agu_ac, &fr_ag,   &fr_ac,   &fr_agu)      // | à         | â          | À          |
TAP_DANCE_2(ec_ecu,    &fr_ec,   &fr_ecu)                // | ê         | Ê          |            |
TAP_DANCE_2(ea_eau,    &fr_ea,   &fr_eau)                // | é         | É          |            |
TAP_DANCE_2(eg_et,     &fr_eg,   &fr_et)                 // | è         | ë          |            |
TAP_DANCE_2(cc_ccu,    &fr_cc,   &fr_ccu)                // | ç         | Ç          |            |
TAP_DANCE_3(ug_uc,     &fr_ug,   &fr_uc,   &fr_mu)       // | ù         | û          | μ          |
TAP_DANCE_2(ic_it,     &fr_ic,   &fr_it)                 // | î         | ï          |            |
TAP_DANCE_2(oc_ocu,    &fr_oc,   &fr_ocu)                // | ô         | Ô          |            |
TAP_DANCE_2(oe_oeu,    &fr_oe,   &fr_oeu)                // | œ         | Œ          |            |
TAP_DANCE_3(nb_2_3, &kp FR_NUMB, &kp FR_EX2, &kp FR_EX3) // | °         | ²          | ³          |

