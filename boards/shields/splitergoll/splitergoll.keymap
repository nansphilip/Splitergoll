//                   ┃ Bootloader┃ ┃           ┃           ┃           ┃           ┃   ┃           ┃           ┃           ┃           ┃ ┃Del BT link┃
//                   ┗━━━━━━━━━━━┛ ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛   ┗━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┻━━━━━━━━━━━┛ ┗━━━━━━━━━━━┛

//         ┃           ┃           ┃           ┃           ┃           ┃           ┃   ┃           ┃           ┃           ┃           ┃           ┃           ┃
        TERTIARY_layer { bindings = <
            &kp F1      &kp F2      &kp F3      &kp F4      &kp F5      &kp F6
            no___       &fr_ocu     &fr_eau     &fr_egu     &fr_ecu     &fr_etu
                        no___       no___       no___       no___       no___
                        &bootloader trs__       trs__       trs__       trs__ 
                                                                                        &kp F7      &kp F8      &kp F9      &kp F10     &kp F11     &kp F12
                                                                                        &fr_ugu     &fr_ccu     &fr_agu     &fr_icu     &fr_itu     no___
                                                                                        no___       no___       no___       no___       no___
                                                                                        trs__       trs__       trs__       trs__       &bt BT_CLR_ALL
        >; sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp UP DOWN>;};
