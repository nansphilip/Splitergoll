    &kp BSPC    &oe_oeu     &nb_2_3     &kp FR_UDSC &kp FR_MINS &kp FR_PLUS
    &kp DEL     &oc_ocu     &ea_eau     &ec_ecu     &eg_et      &kp FR_ASTR
                &ic_it      &ug_uc      &cc_ccu     &ag_agu_ac  &kp FR_DIVI
                no___       &kp ENTER   trs__       trs__       trs__
                                                                                &kp FR_EQAL &kp FR_7    &kp FR_8    &kp FR_9    &kp FR_EURO trs__
                                                                                &kp FR_0    &kp FR_4    &kp FR_5    &kp FR_6    &kp FR_DOLR trs__
                                                                                &kp KP_DOT  &kp FR_1    &kp FR_2    &kp FR_3    &kp FR_PERC
                                                                                &kp SPACE   trs__       trs__       trs__       no___
