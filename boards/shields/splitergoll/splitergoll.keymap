//         ┃           ┃           ┃           ┃           ┃           ┃           ┃   ┃           ┃           ┃           ┃           ┃           ┃           ┃
        SECONDARY_layer { bindings = <
            &kp BSPC    no___       &kp HOME    no___       &kp END     no___
            &kp DEL     no___       &kp LEFT    &kp UP      &kp RIGHT   no___
                        no___      &kp LC(LEFT) &kp DOWN  &kp LC(RIGHT) no___
                        no___       trs__       trs__       trs__       trs__ 
                                                                                        no___       no___       no___       no___       no___       no___
                                                                                        no___       no___       no___       no___       no___       no___
                                                                                        no___       no___       no___       no___       no___
                                                                                        trs__       trs__       trs__       trs__       no___
        >; sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp UP DOWN>;};
